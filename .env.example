# Nginx
NGINX_TAG=1.30-alpine
PROXY_HTTP_PUBLISHED_PORT=8080

# Asp.NET Core
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL
POSTGRES_TAG=17-alpine
POSTGRES_DB=nextalk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_TAG=8.6.2-alpine

# Zitadel database connection
ZITADEL_DATABASE_POSTGRES_DSN=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable

# NexTalk database connection
NEXTALK_DATABASE_POSTGRES_DSN=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable

# Zitadel
ZITADEL_TAG=v4.13.1
ZITADEL_LOGIN_TAG=v4.13.1
ZITADEL_DOMAIN=localhost
ZITADEL_EXTERNALPORT=8080
ZITADEL_EXTERNALSECURE=false
ZITADEL_PUBLIC_SCHEME=http
# Masterkey должен быть 32 символа, иначе ZITADEL не запустится
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# Zitadel additional settings
ZITADEL_ACCESS_LOG_STDOUT_ENABLED=false
LOGIN_CLIENT_PAT_EXPIRATION=2099-12-31T23:59:59Z

# LiveKit - должны совпадать с keys в infra/livekit/livekit.yaml
LIVEKIT_IMAGE=v1.11
LIVEKIT_API_KEY=devkey
LIVEKIT_SECRET_KEY=devsecret
